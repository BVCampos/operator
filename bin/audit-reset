#!/bin/bash
# audit-reset — Clear all audit state files to start a fresh audit cycle
# Usage: audit-reset [--force]

set -e

FORCE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --force|-f)
      FORCE=true
      shift
      ;;
    -h|--help)
      echo "Usage: audit-reset [--force]"
      echo ""
      echo "Removes all audit state files so you can start a fresh audit cycle."
      echo ""
      echo "Files removed:"
      echo "  audit-progress.md          Section tracking"
      echo "  audit-report.md            Findings"
      echo "  audit-report-verified.md   Verified findings"
      echo "  audit-fix-progress.md      Fix tracking"
      echo "  audit-fix-changelog.md     Fix log"
      echo ""
      echo "Options:"
      echo "  --force, -f    Skip confirmation prompt"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: Not inside a git repository."
  exit 1
fi

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

FILES=(
  audit-progress.md
  audit-report.md
  audit-report-verified.md
  audit-fix-progress.md
  audit-fix-changelog.md
)

# Check what exists
FOUND=()
for f in "${FILES[@]}"; do
  [ -f "$f" ] && FOUND+=("$f")
done

if [ ${#FOUND[@]} -eq 0 ]; then
  echo "No audit state files found. Nothing to reset."
  exit 0
fi

echo "Audit state files found:"
for f in "${FOUND[@]}"; do
  echo "  $f"
done
echo ""

if [ "$FORCE" = false ]; then
  read -p "Remove these files and start fresh? [y/N] " -n 1 -r
  echo ""
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    exit 0
  fi
fi

for f in "${FOUND[@]}"; do
  rm "$f"
  echo "  Removed $f"
done

echo ""
echo "Audit state cleared. Run 'operator audit' or 'operator audit full' to start a new cycle."
