#!/bin/bash
# review-loop — Review PR, fix issues, repeat until clean
# Usage: review-loop [--max N] [--model MODEL] [--effort LEVEL] [--review-only] [--fix-only]

set -e

OPERATOR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROMPTS_DIR="$OPERATOR_DIR/prompts"
REVIEW_PROMPT="$PROMPTS_DIR/review-phase.md"
FIX_PROMPT="$PROMPTS_DIR/fix-phase.md"
VERIFY_PROMPT="$PROMPTS_DIR/review-verify-phase.md"

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"
setup_log "review-loop"

# Defaults
MAX_ITERATIONS=3
NO_COMMIT=true
REVIEW_ONLY=false
FIX_ONLY=false
SKIP_VERIFY=false
VERIFY_THRESHOLD=7

# Parse arguments
while [[ $# -gt 0 ]]; do
  if try_parse_common "$@"; then
    shift $PARSED_SHIFT
    continue
  fi
  case $1 in
    --max)
      MAX_ITERATIONS="$2"
      shift 2
      ;;
    --commit)
      NO_COMMIT=false
      shift
      ;;
    --review-only)
      REVIEW_ONLY=true
      shift
      ;;
    --fix-only)
      FIX_ONLY=true
      shift
      ;;
    --skip-verify)
      SKIP_VERIFY=true
      shift
      ;;
    --verify-threshold)
      VERIFY_THRESHOLD="$2"
      shift 2
      ;;
    -h|--help)
      echo "Usage: review-loop [--max N] [--model MODEL] [--effort LEVEL] [--timeout MIN] [--review-only] [--fix-only] [--skip-verify]"
      echo ""
      echo "Runs a review → fix → verify loop on the current branch's changes."
      echo "The verify phase independently evaluates fixes with a scoring rubric."
      echo ""
      echo "Options:"
      echo "  --max N               Max iterations (default: 3)"
      echo "  --model MODEL         Claude model to use (e.g., sonnet, opus)"
      echo "  --effort LEVEL        Thinking effort: low, medium, high, max (default: Claude's default)"
      echo "  --timeout MIN         Kill claude after MIN minutes with no output (default: 15)"
      echo "  --commit              Commit fixes automatically (default: no commit, changes left staged)"
      echo "  --review-only         Only run the review phase (no fixes)"
      echo "  --fix-only            Only run the fix phase (assumes review-report.md exists)"
      echo "  --skip-verify         Skip the independent verification phase"
      echo "  --verify-threshold N  Minimum score to pass verification (default: 7)"
      echo ""
      echo "The loop stops early when verification scores all fixes >= threshold."
      exit 0
      ;;
    *)
      # Assume it's max_iterations if it's a number
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        MAX_ITERATIONS="$1"
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

validate_env
build_claude_cmd

CHANGED_FILES=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
BRANCH_DIFF=$(git diff main...HEAD --name-only 2>/dev/null | wc -l | tr -d ' ')

echo "================================================"
echo "  Review Loop — Max iterations: $MAX_ITERATIONS"
echo "  Project: $PROJECT_DIR"
echo "  Branch:  $(git branch --show-current)"
[ -n "$MODEL" ] && echo "  Model:   $MODEL"
[ -n "$EFFORT" ] && echo "  Effort:  $EFFORT"
[ "$NO_COMMIT" = false ] && echo "  Commit:  enabled"
if [ "$SKIP_VERIFY" = false ]; then
  echo "  Verify:  enabled (threshold: $VERIFY_THRESHOLD/10)"
else
  echo "  Verify:  disabled"
fi
echo "  Stall:   kill after ${CLAUDE_TIMEOUT}m with no output"
echo "  Log:     $LOG_FILE"
echo "  Changed: $CHANGED_FILES unstaged, $STAGED_FILES staged, $BRANCH_DIFF vs main"
echo "================================================"
echo ""
CHANGELOG="$PROJECT_DIR/review-changelog.md"

log "Started review-loop --max $MAX_ITERATIONS"
log "Project: $PROJECT_DIR | Branch: $(git branch --show-current)"
log "Files: $CHANGED_FILES unstaged, $STAGED_FILES staged, $BRANCH_DIFF vs main"
log "Changelog: $CHANGELOG"

for i in $(seq 1 $MAX_ITERATIONS); do
  echo ""
  echo "==============================================================="
  echo "  Iteration $i of $MAX_ITERATIONS"
  echo "==============================================================="

  # Phase 1: Review
  if [ "$FIX_ONLY" = false ]; then
    echo ""
    log "--- Phase 1: REVIEW ---"
    echo ""

    if ! run_claude "$REVIEW_PROMPT" "Reviewing code"; then
      log "Review phase stalled (no output for ${CLAUDE_TIMEOUT}m) — retrying"
      sleep 2
      continue
    fi
    OUTPUT="$CLAUDE_OUTPUT"

    # Log a preview of the output
    LINES=$(echo "$OUTPUT" | wc -l | tr -d ' ')
    log "Review output: $LINES lines"

    # Show the output
    echo ""
    echo "$OUTPUT"
    echo "$OUTPUT" >> "$LOG_FILE"

    # Check for clean signal
    if echo "$OUTPUT" | grep -q "<review>CLEAN</review>"; then
      echo ""
      log "================================================"
      log "  Review is CLEAN! No critical/important issues."
      log "  Completed at iteration $i of $MAX_ITERATIONS"
      log "================================================"
      if [ -f "$CHANGELOG" ]; then
        echo ""
        log "Changelog: $CHANGELOG"
        ITER_COUNT=$(grep -c "^## Iteration" "$CHANGELOG" 2>/dev/null) || ITER_COUNT=0
        log "Total entries: $ITER_COUNT"
      fi
      exit 0
    fi

    # Verify review report was created
    if [ ! -f "$PROJECT_DIR/review-report.md" ]; then
      log "Warning: review-report.md was not created. The review may have failed."
      log "Continuing to next iteration..."
      continue
    fi

    # Show summary from the report
    if [ -f "$PROJECT_DIR/review-report.md" ]; then
      echo ""
      log "Review report saved to review-report.md"
      SUMMARY=$(grep -A5 "## Summary" "$PROJECT_DIR/review-report.md" 2>/dev/null || echo "  (no summary section found)")
      echo "$SUMMARY"
    fi

    if [ "$REVIEW_ONLY" = true ]; then
      echo ""
      log "Review-only mode. Run 'review-loop --fix-only' to fix the issues."
      exit 0
    fi
  fi

  # Phase 2: Fix
  echo ""
  log "--- Phase 2: FIX ---"
  echo ""

  if [ ! -f "$PROJECT_DIR/review-report.md" ]; then
    log "Error: No review-report.md found. Run without --fix-only first."
    exit 1
  fi

  # Build fix prompt (append no-commit override if needed)
  FIX_INPUT="$FIX_PROMPT"
  if [ "$NO_COMMIT" = true ]; then
    FIX_INPUT=$(mktemp)
    cat "$FIX_PROMPT" > "$FIX_INPUT"
    printf '\n## OVERRIDE: No Commit\n\nDo NOT run git commit. Stage all changes with `git add` but leave them uncommitted. Skip step 6 entirely.\n' >> "$FIX_INPUT"
  fi

  if ! run_claude "$FIX_INPUT" "Fixing issues"; then
    log "Fix phase stalled (no output for ${CLAUDE_TIMEOUT}m) — retrying"
    [ "$NO_COMMIT" = true ] && rm -f "$FIX_INPUT"
    sleep 2
    continue
  fi
  OUTPUT="$CLAUDE_OUTPUT"
  [ "$NO_COMMIT" = true ] && rm -f "$FIX_INPUT"

  LINES=$(echo "$OUTPUT" | wc -l | tr -d ' ')
  log "Fix output: $LINES lines"

  # Show the output
  echo ""
  echo "$OUTPUT"
  echo "$OUTPUT" >> "$LOG_FILE"

  # Show git status after fixes
  echo ""
  log "Git status after fix:"
  CHANGED_AFTER=$(git diff --name-only 2>/dev/null)
  if [ -n "$CHANGED_AFTER" ]; then
    echo "$CHANGED_AFTER" | while read -r f; do log "  modified: $f"; done
  fi
  COMMITTED=$(git log --oneline -1 2>/dev/null)
  log "Latest commit: $COMMITTED"

  # Phase 3: Verify (independent evaluator)
  if [ "$SKIP_VERIFY" = false ] && [ -f "$PROJECT_DIR/review-report.md" ]; then
    echo ""
    log "--- Phase 3: VERIFY (independent evaluator) ---"
    echo ""

    if ! run_claude "$VERIFY_PROMPT" "Verifying fixes"; then
      log "Verify phase stalled (no output for ${CLAUDE_TIMEOUT}m) — skipping verification"
    else
      OUTPUT="$CLAUDE_OUTPUT"

      LINES=$(echo "$OUTPUT" | wc -l | tr -d ' ')
      log "Verify output: $LINES lines"

      echo ""
      echo "$OUTPUT"
      echo "$OUTPUT" >> "$LOG_FILE"

      # Parse overall score from output
      OVERALL_SCORE=$(echo "$OUTPUT" | grep -oP 'Overall score: \K[0-9]+\.?[0-9]*' | head -1)
      if [ -z "$OVERALL_SCORE" ]; then
        OVERALL_SCORE=$(echo "$OUTPUT" | grep -oP 'Overall: \K[0-9]+\.?[0-9]*' | head -1)
      fi

      if [ -n "$OVERALL_SCORE" ]; then
        log "Verification score: $OVERALL_SCORE/10 (threshold: $VERIFY_THRESHOLD)"
      fi

      # Check for pass signal
      if echo "$OUTPUT" | grep -q "<verify>PASS</verify>"; then
        echo ""
        log "================================================"
        log "  Verification PASSED! Score: ${OVERALL_SCORE:-N/A}/10"
        log "  All fixes verified by independent evaluator."
        log "  Completed at iteration $i of $MAX_ITERATIONS"
        log "================================================"
        if [ -f "$CHANGELOG" ]; then
          ITER_COUNT=$(grep -c "^## Iteration" "$CHANGELOG" 2>/dev/null) || ITER_COUNT=0
          log "Changelog: $CHANGELOG ($ITER_COUNT entries)"
        fi
        exit 0
      else
        log "Verification: NEEDS_WORK (score: ${OVERALL_SCORE:-N/A}/10) — continuing to next iteration"
        # Parse fail/unfixed counts for logging
        FAIL_COUNT=$(echo "$OUTPUT" | grep -oP 'FAIL[^:]*: \K[0-9]+' | head -1)
        UNFIXED_COUNT=$(echo "$OUTPUT" | grep -oP 'UNFIXED: \K[0-9]+' | head -1)
        [ -n "$FAIL_COUNT" ] && [ "$FAIL_COUNT" -gt 0 ] && log "  Failed fixes: $FAIL_COUNT"
        [ -n "$UNFIXED_COUNT" ] && [ "$UNFIXED_COUNT" -gt 0 ] && log "  Unfixed findings: $UNFIXED_COUNT"
      fi
    fi
  fi

  # Reset fix-only flag after first iteration
  FIX_ONLY=false

  echo ""
  log "Iteration $i complete."
  sleep 2
done

echo ""
log "================================================"
log "  Reached max iterations ($MAX_ITERATIONS)."
log "  Check review-report.md for remaining issues."
[ -f "$PROJECT_DIR/review-verify.md" ] && log "  Verification: review-verify.md"
log "  Full log: $LOG_FILE"
if [ -f "$CHANGELOG" ]; then
  ITER_COUNT=$(grep -c "^## Iteration" "$CHANGELOG" 2>/dev/null) || ITER_COUNT=0
  log "  Changelog: $CHANGELOG ($ITER_COUNT entries)"
fi
log "================================================"
exit 2
