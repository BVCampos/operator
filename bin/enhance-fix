#!/bin/bash
# enhance-fix — Implement enhancement suggestions (sequential by default, parallel with --parallel)
# Usage: enhance-fix [--max N] [--parallel [N]] [--model MODEL] [--effort LEVEL]

set -e

OPERATOR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROMPTS_DIR="$OPERATOR_DIR/prompts"
FIX_PROMPT="$PROMPTS_DIR/enhance-fix-phase.md"
REPAIR_PROMPT="$PROMPTS_DIR/enhance-fix-repair-phase.md"
CONTRACT_PROMPT="$PROMPTS_DIR/enhance-fix-contract-phase.md"

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"
setup_log "enhance-fix"

# Defaults
MAX_SECTIONS=0  # 0 = all unimplemented
MAX_PARALLEL=5  # concurrent Claude instances (API rate limit safe)
MAX_REPAIRS=3
NO_COMMIT=true
NO_REPAIR=false
SKIP_CONTRACTS=false
PARALLEL=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  if try_parse_common "$@"; then
    shift $PARSED_SHIFT
    continue
  fi
  case $1 in
    --commit)
      NO_COMMIT=false
      shift
      ;;
    --no-repair)
      NO_REPAIR=true
      shift
      ;;
    --skip-contracts)
      SKIP_CONTRACTS=true
      shift
      ;;
    --max-repairs)
      MAX_REPAIRS="$2"
      shift 2
      ;;
    --max)
      MAX_SECTIONS="$2"
      shift 2
      ;;
    --parallel)
      PARALLEL=true
      if [[ -n "${2:-}" && "$2" =~ ^[0-9]+$ ]]; then
        MAX_PARALLEL="$2"
        shift 2
      else
        shift
      fi
      ;;
    -h|--help)
      echo "Usage: enhance-fix [--max N] [--parallel [N]] [--model MODEL] [--effort LEVEL] [--timeout MIN]"
      echo ""
      echo "Implements enhancement suggestions sequentially — one section at a time on the current branch."
      echo "Each section builds on the previous one's changes, so there are no merge conflicts."
      echo ""
      echo "Options:"
      echo "  --commit         Commit progress automatically (default: no commit, changes left staged)"
      echo "  --max N          Max sections to enhance (default: all)"
      echo "  --parallel [N]   Run sections in parallel using worktrees (default: sequential)"
      echo "                   N = max concurrent Claude instances (default: 5)"
      echo "  --model MODEL    Claude model to use (e.g., sonnet)"
      echo "  --effort LEVEL   Thinking effort: low, medium, high, max"
      echo "  --timeout MIN    Kill claude after MIN minutes with no output (default: 15)"
      echo "  --no-repair      Skip the auto-repair phase if checks fail"
      echo "  --max-repairs N  Max repair iterations (default: 3)"
      echo "  --skip-contracts Skip the verification contract generation phase"
      exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        MAX_SECTIONS="$1"
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

validate_env
build_claude_cmd

BASE_BRANCH=$(git branch --show-current)

# If we're on a leftover enhance-fix branch from a previous failed run, switch back
if [[ "$BASE_BRANCH" == enhance-fix/* ]]; then
  for candidate in main master; do
    if git rev-parse --verify "$candidate" &>/dev/null; then
      log "Warning: on leftover branch '$BASE_BRANCH' — switching to $candidate"
      git checkout "$candidate" --quiet
      BASE_BRANCH="$candidate"
      break
    fi
  done
  if [[ "$BASE_BRANCH" == enhance-fix/* ]]; then
    echo "Error: on enhance-fix branch and cannot find main/master to switch to."
    exit 1
  fi
fi

BASE_COMMIT=$(git rev-parse HEAD)

# Pre-clean stale enhance-fix branches/worktrees from previous parallel runs
for stale in $(git branch --list 'enhance-fix/*' 2>/dev/null | sed 's/^[* ]*//'); do
  stale_name="${stale#enhance-fix/}"
  git worktree remove "$PROJECT_DIR/.enhance-fix-worktrees/$stale_name" --force 2>/dev/null || true
  rm -rf "$PROJECT_DIR/.enhance-fix-worktrees/$stale_name" 2>/dev/null || true
  git branch -D "$stale" 2>/dev/null || true
done
rmdir "$PROJECT_DIR/.enhance-fix-worktrees" 2>/dev/null || true

# Prefer verified report
if [ -f "$PROJECT_DIR/enhance-report-verified.md" ]; then
  REPORT_FILE="$PROJECT_DIR/enhance-report-verified.md"
  log "Using verified report: enhance-report-verified.md"
elif [ -f "$PROJECT_DIR/enhance-report.md" ]; then
  REPORT_FILE="$PROJECT_DIR/enhance-report.md"
  log "Using unverified report: enhance-report.md"
else
  echo "Error: No enhance report found. Run 'operator enhance' first."
  exit 1
fi

PROGRESS_FILE="$PROJECT_DIR/enhance-fix-progress.md"
CHANGELOG_FILE="$PROJECT_DIR/enhance-fix-changelog.md"

# ── Extract sections from report ────────────────────────────────────

ALL_SECTIONS=()
while IFS= read -r line; do
  ALL_SECTIONS+=("$(echo "$line" | sed 's/^## //' | sed 's/ — .*//')")
done < <(grep "^## " "$REPORT_FILE")

ALL_COUNT=${#ALL_SECTIONS[@]}

if [ "$ALL_COUNT" -eq 0 ]; then
  echo "Error: No sections found in enhance report."
  exit 1
fi

# ── Filter to unimplemented sections ──────────────────────────────

SECTIONS=()
if [ -f "$PROGRESS_FILE" ]; then
  for section in "${ALL_SECTIONS[@]}"; do
    if ! grep -F "[x]" "$PROGRESS_FILE" 2>/dev/null | grep -qF "$section"; then
      SECTIONS+=("$section")
    fi
  done
else
  SECTIONS=("${ALL_SECTIONS[@]}")
fi

SECTION_COUNT=${#SECTIONS[@]}

if [ "$SECTION_COUNT" -eq 0 ]; then
  log "All sections already enhanced!"
  exit 0
fi

# Apply max limit
if [ "$MAX_SECTIONS" -gt 0 ] && [ "$MAX_SECTIONS" -lt "$SECTION_COUNT" ]; then
  SECTIONS=("${SECTIONS[@]:0:$MAX_SECTIONS}")
  SECTION_COUNT=${#SECTIONS[@]}
fi

MODE_LABEL="sequential"
[ "$PARALLEL" = true ] && MODE_LABEL="parallel ($MAX_PARALLEL concurrent)"

echo "================================================"
echo "  Enhance Fix — $SECTION_COUNT sections ($MODE_LABEL)"
[ -n "$MODEL" ] && echo "  Model:    $MODEL"
[ -n "$EFFORT" ] && echo "  Effort:   $EFFORT"
echo "  Stall:    kill after ${CLAUDE_TIMEOUT}m with no output"
[ "$SKIP_CONTRACTS" = false ] && echo "  Contracts: enabled (verification contracts before implementing)"
[ "$SKIP_CONTRACTS" = true ] && echo "  Contracts: disabled"
[ "$NO_REPAIR" = true ] && echo "  Repair:   disabled"
[ "$NO_COMMIT" = false ] && echo "  Commit:   enabled"
echo "  Project:  $PROJECT_DIR"
echo "  Branch:   $BASE_BRANCH"
echo "  Report:   $(basename "$REPORT_FILE")"
echo "  Log:      $LOG_FILE"
echo "================================================"
echo ""
log "Started enhance-fix — $SECTION_COUNT sections ($MODE_LABEL)"
log "Base commit: $BASE_COMMIT"

# ── Generate verification contracts ──────────────────────────────────

CONTRACT_FILE="$PROJECT_DIR/enhance-fix-contracts.md"
CONTRACTS_CONTENT=""

if [ "$SKIP_CONTRACTS" = false ] && [ -f "$CONTRACT_PROMPT" ]; then
  echo ""
  log "Generating verification contracts (defining 'done' before implementing)..."

  CONTRACT_INPUT=$(mktemp)
  cat "$CONTRACT_PROMPT" > "$CONTRACT_INPUT"
  printf '\n---\n\n## Enhance Report\n\n' >> "$CONTRACT_INPUT"
  cat "$REPORT_FILE" >> "$CONTRACT_INPUT"

  # Run in a temp dir so Claude can't edit source files (it has --dangerously-skip-permissions)
  CONTRACT_SANDBOX=$(mktemp -d)
  if run_claude "$CONTRACT_INPUT" "Generating verification contracts" "$CONTRACT_SANDBOX"; then
    CONTRACTS_CONTENT="$CLAUDE_OUTPUT"
    echo "$CONTRACTS_CONTENT" > "$CONTRACT_FILE"
    log "Contracts written to enhance-fix-contracts.md"

    # Count contracts generated
    CONTRACT_COUNT=$(echo "$CONTRACTS_CONTENT" | grep -c "^### " 2>/dev/null) || CONTRACT_COUNT=0
    log "Generated $CONTRACT_COUNT verification contracts"
  else
    log "Contract generation stalled — proceeding without contracts"
  fi
  rm -f "$CONTRACT_INPUT"
  rm -rf "$CONTRACT_SANDBOX"
  echo ""
fi

# ── Build prompts ────────────────────────────────────────────────────

FIX_TEMPLATE=$(cat "$FIX_PROMPT")
WORK_DIR=$(mktemp -d)

cleanup() {
  cd "$PROJECT_DIR" 2>/dev/null || true
  if [ "$PARALLEL" = true ]; then
    for name in "${SANITIZED_NAMES[@]}"; do
      git worktree remove "${WORKTREE_BASE:-/tmp}/$name" --force 2>/dev/null || rm -rf "${WORKTREE_BASE:-/tmp}/$name"
      git branch -D "enhance-fix/$name" 2>/dev/null || true
    done
    for stale in $(git branch --list 'enhance-fix/*' 2>/dev/null | sed 's/^[* ]*//'); do
      local stale_name="${stale#enhance-fix/}"
      git worktree remove "${WORKTREE_BASE:-/tmp}/$stale_name" --force 2>/dev/null || rm -rf "${WORKTREE_BASE:-/tmp}/$stale_name" 2>/dev/null || true
      git branch -D "$stale" 2>/dev/null || true
    done
    rmdir "${WORKTREE_BASE:-/tmp/noop}" 2>/dev/null || true
  fi
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

START_TIME=$(date +%s)

for i in "${!SECTIONS[@]}"; do
  section="${SECTIONS[$i]}"
  idx=$((i + 1))

  SECTION_CONTENT=$(extract_section "$REPORT_FILE" "$section")

  # Extract contract for this section (if contracts were generated)
  SECTION_CONTRACT=""
  if [ -n "$CONTRACTS_CONTENT" ]; then
    SECTION_CONTRACT=$(echo "$CONTRACTS_CONTENT" | awk -v section="$section" '
      tolower($0) ~ tolower(section) { found=1; print; next }
      found && /^## / { exit }
      found { print }
    ')
  fi

  # Build per-section prompt
  cat > "$WORK_DIR/prompt-$idx.md" <<PROMPT_EOF
$FIX_TEMPLATE

---

## Section to enhance (${idx} of ${SECTION_COUNT})

**Section name:** $section

### Suggestions to implement

$SECTION_CONTENT
PROMPT_EOF

  # Append contract if available
  if [ -n "$SECTION_CONTRACT" ]; then
    cat >> "$WORK_DIR/prompt-$idx.md" <<CONTRACT_EOF

### Verification Contract

The following contract defines what "enhanced" means for each suggestion. Your changes MUST satisfy these conditions. After implementing, verify each DONE-when condition and run each VERIFY-by command.

$SECTION_CONTRACT
CONTRACT_EOF
  fi
done

# ── Execute enhancements ─────────────────────────────────────────────

MERGED_SECTIONS=()
CONFLICT_SECTIONS=()
SANITIZED_NAMES=()

if [ "$PARALLEL" = true ]; then
  # ── Parallel mode: worktrees + batch execution + two-pass merge ──

  WORKTREE_BASE="$PROJECT_DIR/.enhance-fix-worktrees"
  mkdir -p "$WORKTREE_BASE"

  PREPARED_INDICES=()

  for i in "${!SECTIONS[@]}"; do
    section="${SECTIONS[$i]}"
    idx=$((i + 1))

    name=$(sanitize_name "$section")
    SANITIZED_NAMES+=("$name")

    branch="enhance-fix/$name"
    wt="$WORKTREE_BASE/$name"

    [ -d "$wt" ] && { git worktree remove "$wt" --force 2>/dev/null || rm -rf "$wt"; }
    git branch -D "$branch" 2>/dev/null || true

    if ! git worktree add -b "$branch" "$wt" "$BASE_COMMIT" --quiet 2>/dev/null; then
      log "  ✗ Failed to create worktree for $section — skipping"
      continue
    fi

    [ -d "$PROJECT_DIR/node_modules" ] && [ ! -e "$wt/node_modules" ] && \
      ln -s "$PROJECT_DIR/node_modules" "$wt/node_modules"

    cp "$REPORT_FILE" "$wt/$(basename "$REPORT_FILE")" 2>/dev/null || true

    PREPARED_INDICES+=("$i")
  done

  # Launch in batches
  ALL_PIDS=()
  TOTAL_PREPARED=${#PREPARED_INDICES[@]}
  BATCH_NUM=0
  TOTAL_FAILURES=0

  for batch_start in $(seq 0 $MAX_PARALLEL $((TOTAL_PREPARED - 1))); do
    BATCH_NUM=$((BATCH_NUM + 1))
    batch_end=$((batch_start + MAX_PARALLEL - 1))
    [ $batch_end -ge $TOTAL_PREPARED ] && batch_end=$((TOTAL_PREPARED - 1))
    batch_size=$((batch_end - batch_start + 1))

    echo ""
    log "Batch $BATCH_NUM: launching $batch_size enhancers (sections $((batch_start + 1))-$((batch_end + 1)) of $TOTAL_PREPARED)"

    BATCH_PIDS=()

    for j in $(seq $batch_start $batch_end); do
      i="${PREPARED_INDICES[$j]}"
      section="${SECTIONS[$i]}"
      idx=$((i + 1))
      name=$(sanitize_name "$section")
      wt="$WORKTREE_BASE/$name"

      (cd "$wt" && command $CLAUDE_CMD < "$WORK_DIR/prompt-$idx.md" > "$WORK_DIR/output-$idx.md" 2>&1) &
      BATCH_PIDS+=($!)
      ALL_PIDS+=($!)

      log "  Launched enhancer: $section (PID: $!)"
      sleep 3
    done

    echo ""
    spin_all "Enhancing batch $BATCH_NUM ($batch_size sections)" "$WORK_DIR" "${BATCH_PIDS[@]}"

    for pid in "${BATCH_PIDS[@]}"; do
      wait "$pid" 2>/dev/null || TOTAL_FAILURES=$((TOTAL_FAILURES + 1))
    done

    [ "$SPIN_TIMED_OUT" = true ] && log "Warning: batch $BATCH_NUM stalled (no output for ${CLAUDE_TIMEOUT}m)"
  done

  echo ""
  [ $TOTAL_FAILURES -gt 0 ] && log "Warning: $TOTAL_FAILURES section(s) had errors"

  # Merge worktree branches back (two-pass: cherry-pick + retry conflicts)
  merge_parallel_branches "enhance-fix" "enhancements"

else
  # ── Sequential mode: enhance sections one at a time on main ──────

  for i in "${!SECTIONS[@]}"; do
    section="${SECTIONS[$i]}"
    idx=$((i + 1))

    echo ""
    log "[$idx/$SECTION_COUNT] Enhancing: $section"

    PRE_FIX=$(git rev-parse HEAD)

    if run_claude "$WORK_DIR/prompt-$idx.md" "$section"; then
      FIX_COMMITS=$(git log --oneline "$PRE_FIX..HEAD" 2>/dev/null | wc -l | tr -d ' ')
      if [ "$FIX_COMMITS" -gt 0 ]; then
        MERGED_SECTIONS+=("$section")
        log "  ✓ $section ($FIX_COMMITS commits)"
      else
        log "  ✗ $section (no commits produced)"
      fi
      [ -n "$CLAUDE_OUTPUT" ] && echo "$CLAUDE_OUTPUT" > "$WORK_DIR/output-$idx.md"
    else
      CONFLICT_SECTIONS+=("$section")
      log "  ✗ $section (stalled)"
    fi
  done

  MERGED=${#MERGED_SECTIONS[@]}

  echo ""
  log "Enhanced: $MERGED/$SECTION_COUNT sections"
  [ ${#CONFLICT_SECTIONS[@]} -gt 0 ] && log "Failed: ${CONFLICT_SECTIONS[*]}"

  # If NO_COMMIT, squash all enhancement commits into staged changes
  if [ "$NO_COMMIT" = true ] && [ "$MERGED" -gt 0 ]; then
    git reset --soft "$BASE_COMMIT" 2>/dev/null || true
  fi
fi

# ── Show enhancement summaries ──────────────────────────────────────

for i in "${!SECTIONS[@]}"; do
  idx=$((i + 1))
  section="${SECTIONS[$i]}"
  if [ -f "$WORK_DIR/output-$idx.md" ] && [ -s "$WORK_DIR/output-$idx.md" ]; then
    echo ""
    log "--- $section ---"
    cat "$WORK_DIR/output-$idx.md"
    cat "$WORK_DIR/output-$idx.md" >> "$LOG_FILE"
  fi
done

# ── Run checks on the combined result ─────────────────────────────

TSC_OK=true
LINT_OK=true
FORMAT_OK=true
TESTS_OK=true
ALL_CHECKS_OK=true
CHECK_ERRORS=""
REPAIR_ITERATION=0

run_checks() {
  TSC_OK=true; LINT_OK=true; FORMAT_OK=true; TESTS_OK=true
  CHECK_ERRORS=""

  echo ""
  log "Running verification on combined result..."

  run_check "Type checking" "tsc" "npx tsc --noEmit" && TSC_OK=true || TSC_OK=false

  if (cd "$PROJECT_DIR" && npx eslint --version &>/dev/null); then
    run_check "Linting (eslint)" "lint" "npx eslint ." 50 && LINT_OK=true || LINT_OK=false
  elif (cd "$PROJECT_DIR" && npx biome --version &>/dev/null); then
    run_check "Linting (biome)" "lint" "npx biome check ." 50 && LINT_OK=true || LINT_OK=false
  else
    log "  lint: no linter found, skipping"
  fi

  if (cd "$PROJECT_DIR" && npx prettier --version &>/dev/null); then
    run_check "Format check (prettier)" "format" "npx prettier --check ." 30 && FORMAT_OK=true || FORMAT_OK=false
  elif (cd "$PROJECT_DIR" && npx biome --version &>/dev/null) && [ "$LINT_OK" != false ]; then
    run_check "Format check (biome)" "format" "npx biome format ." 30 && FORMAT_OK=true || FORMAT_OK=false
  else
    log "  format: no formatter found, skipping"
  fi

  run_check "Running tests" "tests" "npm test" 50 && TESTS_OK=true || TESTS_OK=false

  if [ "$TSC_OK" = true ] && [ "$LINT_OK" = true ] && [ "$FORMAT_OK" = true ] && [ "$TESTS_OK" = true ]; then
    ALL_CHECKS_OK=true
  else
    ALL_CHECKS_OK=false
  fi
}

if [ "$MERGED" -gt 0 ] && [ -f "$PROJECT_DIR/package.json" ]; then
  run_checks

  # ── Auto-repair loop ────────────────────────────────────────────────

  if [ "$ALL_CHECKS_OK" = false ] && [ "$NO_REPAIR" = false ]; then
    REPAIR_TEMPLATE=$(cat "$REPAIR_PROMPT")

    while [ "$ALL_CHECKS_OK" = false ] && [ "$REPAIR_ITERATION" -lt "$MAX_REPAIRS" ]; do
      REPAIR_ITERATION=$((REPAIR_ITERATION + 1))
      echo ""
      log "Repair iteration $REPAIR_ITERATION/$MAX_REPAIRS — launching Claude to fix breakages..."

      REPAIR_INPUT=$(mktemp)
      cat > "$REPAIR_INPUT" <<REPAIR_EOF
$REPAIR_TEMPLATE

---

## Failing checks (repair iteration $REPAIR_ITERATION)

$CHECK_ERRORS
REPAIR_EOF

      run_claude "$REPAIR_INPUT" "Repairing (iteration $REPAIR_ITERATION)" || true
      if [ -n "$CLAUDE_OUTPUT" ]; then
        log "--- Repair output (iteration $REPAIR_ITERATION) ---"
        echo "$CLAUDE_OUTPUT"
        echo "$CLAUDE_OUTPUT" >> "$LOG_FILE"
      fi
      rm -f "$REPAIR_INPUT"

      # Re-run checks
      run_checks
    done

    if [ "$ALL_CHECKS_OK" = false ]; then
      log "Warning: checks still failing after $MAX_REPAIRS repair iterations"
    else
      log "Repair successful after $REPAIR_ITERATION iteration(s)"
    fi
  fi
fi

# ── Update progress and changelog ───────────────────────────────────

# Create progress file if needed
if [ ! -f "$PROGRESS_FILE" ]; then
  {
    echo "# Enhance Fix Progress"
    echo ""
    echo "## Sections"
    for section in "${ALL_SECTIONS[@]}"; do
      echo "- [ ] $section"
    done
  } > "$PROGRESS_FILE"
fi

# Mark merged sections as enhanced
for section in "${MERGED_SECTIONS[@]}"; do
  TEMP_PF=$(mktemp)
  while IFS= read -r line; do
    if echo "$line" | grep -qF "[ ] $section"; then
      echo "- [x] $section — Enhanced $(date '+%Y-%m-%d')"
    else
      echo "$line"
    fi
  done < "$PROGRESS_FILE" > "$TEMP_PF"
  mv "$TEMP_PF" "$PROGRESS_FILE"
done

# Append to changelog
if [ ! -f "$CHANGELOG_FILE" ]; then
  echo "# Enhance Fix Changelog" > "$CHANGELOG_FILE"
  echo "" >> "$CHANGELOG_FILE"
fi

FIX_MODE="Sequential"
[ "$PARALLEL" = true ] && FIX_MODE="Parallel"

{
  echo "## $FIX_MODE Enhance — $(date '+%Y-%m-%d %H:%M')"
  echo ""
  echo "Sections enhanced: $MERGED/$SECTION_COUNT"
  [ ${#CONFLICT_SECTIONS[@]} -gt 0 ] && echo "Conflicts (skipped): ${CONFLICT_SECTIONS[*]}"
  echo ""

  for i in "${!SECTIONS[@]}"; do
    idx=$((i + 1))
    section="${SECTIONS[$i]}"
    if [ -f "$WORK_DIR/output-$idx.md" ] && [ -s "$WORK_DIR/output-$idx.md" ]; then
      echo "### $section"
      echo ""
      cat "$WORK_DIR/output-$idx.md"
      echo ""
    fi
  done

  echo "### Verification"
  echo "- tsc: $([ "$TSC_OK" = true ] && echo "clean" || echo "errors")"
  echo "- lint: $([ "$LINT_OK" = true ] && echo "clean" || echo "errors")"
  echo "- format: $([ "$FORMAT_OK" = true ] && echo "clean" || echo "errors")"
  echo "- tests: $([ "$TESTS_OK" = true ] && echo "passing" || echo "failures")"
  [ "$REPAIR_ITERATION" -gt 0 ] && echo "- repair: $REPAIR_ITERATION iteration(s), $([ "$ALL_CHECKS_OK" = true ] && echo "fixed" || echo "still failing")"
  echo ""

  echo "### Metrics"
  echo "- Mode: $FIX_MODE"
  echo "- Sections attempted: $SECTION_COUNT"
  echo "- Sections merged: $MERGED/$SECTION_COUNT ($(( MERGED * 100 / (SECTION_COUNT > 0 ? SECTION_COUNT : 1) ))%)"
  echo "- Conflicts: ${#CONFLICT_SECTIONS[@]}"
  echo "- Repair iterations needed: $REPAIR_ITERATION"
  echo "- All checks passing: $([ "$ALL_CHECKS_OK" = true ] && echo "yes" || echo "no")"
  [ -n "$CONTRACTS_CONTENT" ] && echo "- Verification contracts: yes ($CONTRACT_COUNT generated)"
  [ -z "$CONTRACTS_CONTENT" ] && echo "- Verification contracts: skipped"
  ELAPSED_SO_FAR=$(( $(date +%s) - START_TIME ))
  echo "- Total time: $(format_elapsed $ELAPSED_SO_FAR)"
  echo ""
  echo "---"
  echo ""
} >> "$CHANGELOG_FILE"

# Commit progress + changelog (only if --commit)
git add "$PROGRESS_FILE" "$CHANGELOG_FILE" 2>/dev/null || true
[ -f "$CONTRACT_FILE" ] && git add "$CONTRACT_FILE" 2>/dev/null || true
if [ "$NO_COMMIT" = false ]; then
  git commit -m "docs(enhance): update fix progress and changelog" 2>/dev/null || true
fi

ELAPSED=$(( $(date +%s) - START_TIME ))

echo ""
log "================================================"
log "  Enhance Fix complete! ($(format_elapsed $ELAPSED))"
log "  Sections enhanced: $MERGED/$SECTION_COUNT"
[ ${#CONFLICT_SECTIONS[@]} -gt 0 ] && log "  Conflicts:      ${CONFLICT_SECTIONS[*]}"
[ "$MERGED" -gt 0 ] && log "  tsc:            $([ "$TSC_OK" = true ] && echo "clean" || echo "errors")"
[ "$MERGED" -gt 0 ] && log "  lint:           $([ "$LINT_OK" = true ] && echo "clean" || echo "errors")"
[ "$MERGED" -gt 0 ] && log "  format:         $([ "$FORMAT_OK" = true ] && echo "clean" || echo "errors")"
[ "$MERGED" -gt 0 ] && log "  tests:          $([ "$TESTS_OK" = true ] && echo "passing" || echo "failures")"
[ "$REPAIR_ITERATION" -gt 0 ] && log "  repair:         $REPAIR_ITERATION iteration(s)"
log "  Progress:       $PROGRESS_FILE"
log "  Changelog:      $CHANGELOG_FILE"
log "================================================"
