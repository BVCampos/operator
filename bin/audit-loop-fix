#!/bin/bash
# audit-loop-fix — Run audit-loop, audit-verify, then audit-fix in sequence
# Usage: audit-loop-fix [--max N] [--audit-max N] [--fix-max N] [--model MODEL] [--effort LEVEL] [--skip-verify]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

# Defaults
AUDIT_MAX=20
FIX_MAX=20
SKIP_VERIFY=false
SKIP_CONTRACTS=false
COMMIT_FLAG=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  if try_parse_common "$@"; then
    shift $PARSED_SHIFT
    continue
  fi
  case $1 in
    --commit)
      COMMIT_FLAG="--commit"
      shift
      ;;
    --max)
      AUDIT_MAX="$2"
      FIX_MAX="$2"
      shift 2
      ;;
    --audit-max)
      AUDIT_MAX="$2"
      shift 2
      ;;
    --verify-max)
      echo "Note: --verify-max is ignored. Verify runs all sections in one parallel pass."
      shift 2
      ;;
    --fix-max)
      FIX_MAX="$2"
      shift 2
      ;;
    --skip-verify)
      SKIP_VERIFY=true
      shift
      ;;
    --skip-contracts)
      SKIP_CONTRACTS=true
      shift
      ;;
    -h|--help)
      echo "Usage: audit-loop-fix [--max N] [--audit-max N] [--fix-max N] [--model MODEL] [--effort LEVEL] [--timeout MIN] [--skip-verify] [--skip-contracts]"
      echo ""
      echo "Runs audit-loop → audit-verify → audit-fix in sequence."
      echo ""
      echo "Options:"
      echo "  --max N          Set audit and fix max values (default: 20)"
      echo "  --audit-max N    Max audit iterations (default: 20)"
      echo "  --fix-max N      Max fix iterations (default: 20)"
      echo "  --commit         Commit fixes automatically (default: no commit, changes left staged)"
      echo "  --model MODEL    Claude model to use (e.g., sonnet)"
      echo "  --effort LEVEL   Thinking effort: low, medium, high, max"
      echo "  --timeout MIN    Kill claude after MIN minutes with no output (default: 15)"
      echo "  --skip-verify    Skip the verification step"
      echo "  --skip-contracts Skip sprint contract generation before fixing"
      exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        AUDIT_MAX="$1"
        FIX_MAX="$1"
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

# Build common flags to forward to subscripts
COMMON_FLAGS=""
[ -n "$MODEL" ] && COMMON_FLAGS="$COMMON_FLAGS --model $MODEL"
[ -n "$EFFORT" ] && COMMON_FLAGS="$COMMON_FLAGS --effort $EFFORT"
[ "$CLAUDE_TIMEOUT" != "15" ] && COMMON_FLAGS="$COMMON_FLAGS --timeout $CLAUDE_TIMEOUT"

echo "================================================"
echo "  Audit + Verify + Fix Pipeline"
echo "  Audit:  up to $AUDIT_MAX iterations"
if [ "$SKIP_VERIFY" = false ]; then
  echo "  Verify: all sections in parallel"
else
  echo "  Verify: skipped"
fi
echo "  Fix:    up to $FIX_MAX sections in parallel"
if [ "$SKIP_CONTRACTS" = false ]; then
  echo "  Contracts: enabled"
else
  echo "  Contracts: skipped"
fi
[ -n "$COMMIT_FLAG" ] && echo "  Commit: enabled"
[ -n "$MODEL" ] && echo "  Model:   $MODEL"
[ -n "$EFFORT" ] && echo "  Effort:  $EFFORT"
[ "$CLAUDE_TIMEOUT" != "15" ] && echo "  Stall:   kill after ${CLAUDE_TIMEOUT}m with no output"
echo "================================================"
echo ""

START_TIME=$(date +%s)

# Phase 1: Audit
echo "[$(date '+%H:%M:%S')] Phase 1: AUDIT"
echo ""
$SCRIPT_DIR/audit-loop --max $AUDIT_MAX $COMMON_FLAGS && AUDIT_EXIT=0 || AUDIT_EXIT=$?

echo ""
echo "[$(date '+%H:%M:%S')] Audit phase finished (exit: $AUDIT_EXIT)"
echo ""

# Exit code 1 = actual error, exit code 2 = max iterations (continue anyway)
if [ $AUDIT_EXIT -eq 1 ]; then
  echo "Audit failed. Stopping."
  exit 1
fi

if [ ! -f "./audit-report.md" ]; then
  echo "No audit-report.md found. Stopping."
  exit 1
fi

# Phase 2: Verify
if [ "$SKIP_VERIFY" = false ]; then
  echo "[$(date '+%H:%M:%S')] Phase 2: VERIFY"
  echo ""
  $SCRIPT_DIR/audit-verify $COMMON_FLAGS && VERIFY_EXIT=0 || VERIFY_EXIT=$?

  echo ""
  echo "[$(date '+%H:%M:%S')] Verify phase finished (exit: $VERIFY_EXIT)"
  echo ""
fi

# Phase 3: Fix
echo "[$(date '+%H:%M:%S')] Phase 3: FIX"
echo ""
CONTRACT_FLAG=""
[ "$SKIP_CONTRACTS" = true ] && CONTRACT_FLAG="--skip-contracts"
$SCRIPT_DIR/audit-fix --max $FIX_MAX $COMMIT_FLAG $CONTRACT_FLAG $COMMON_FLAGS && FIX_EXIT=0 || FIX_EXIT=$?

ELAPSED=$(( $(date +%s) - START_TIME ))

echo ""
echo "================================================"
echo "  [$(date '+%H:%M:%S')] Pipeline complete ($(format_elapsed $ELAPSED))"
echo "  Reports:"
echo "    audit-report.md            Findings"
if [ "$SKIP_VERIFY" = false ]; then
  echo "    audit-report-verified.md   Verified findings"
fi
echo "    audit-fix-contracts.md     Verification contracts"
echo "    audit-fix-changelog.md     Fixes applied"
echo "================================================"
