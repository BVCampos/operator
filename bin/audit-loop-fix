#!/bin/bash
# audit-loop-fix — Run audit-loop, audit-verify, then audit-fix in sequence
# Usage: audit-loop-fix [--max N] [--audit-max N] [--fix-max N] [--model MODEL] [--effort LEVEL] [--skip-verify]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Defaults
AUDIT_MAX=20
FIX_MAX=20
SKIP_VERIFY=false
COMMIT_FLAG=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --commit)
      COMMIT_FLAG="--commit"
      shift
      ;;
    --max)
      AUDIT_MAX="$2"
      FIX_MAX="$2"
      shift 2
      ;;
    --audit-max)
      AUDIT_MAX="$2"
      shift 2
      ;;
    --verify-max)
      echo "Note: --verify-max is ignored. Verify runs all sections in one parallel pass."
      shift 2
      ;;
    --fix-max)
      FIX_MAX="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    --effort)
      EFFORT="$2"
      shift 2
      ;;
    --timeout)
      TIMEOUT="$2"
      shift 2
      ;;
    --skip-verify)
      SKIP_VERIFY=true
      shift
      ;;
    -h|--help)
      echo "Usage: audit-loop-fix [--max N] [--audit-max N] [--fix-max N] [--model MODEL] [--effort LEVEL] [--timeout MIN] [--skip-verify]"
      echo ""
      echo "Runs audit-loop → audit-verify → audit-fix in sequence."
      echo ""
      echo "Options:"
      echo "  --max N          Set audit and fix max values (default: 20)"
      echo "  --audit-max N    Max audit iterations (default: 20)"
      echo "  --fix-max N      Max fix iterations (default: 20)"
      echo "  --commit         Commit fixes automatically (default: no commit, changes left staged)"
      echo "  --model MODEL    Claude model to use (e.g., sonnet)"
      echo "  --effort LEVEL   Thinking effort: low, medium, high, max"
      echo "  --timeout MIN    Kill claude if a step exceeds MIN minutes (default: 30)"
      echo "  --skip-verify    Skip the verification step"
      exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        AUDIT_MAX="$1"
        FIX_MAX="$1"
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

echo "================================================"
echo "  Audit + Verify + Fix Pipeline"
echo "  Audit:  up to $AUDIT_MAX iterations"
if [ "$SKIP_VERIFY" = false ]; then
  echo "  Verify: all sections in parallel"
else
  echo "  Verify: skipped"
fi
echo "  Fix:    up to $FIX_MAX sections in parallel"
[ -n "$COMMIT_FLAG" ] && echo "  Commit: enabled"
[ -n "$MODEL" ] && echo "  Model:   $MODEL"
[ -n "$EFFORT" ] && echo "  Effort:  $EFFORT"
[ -n "$TIMEOUT" ] && echo "  Timeout: ${TIMEOUT}m per step"
echo "================================================"
echo ""

START_TIME=$(date +%s)

# Phase 1: Audit
echo "[$(date '+%H:%M:%S')] Phase 1: AUDIT"
echo ""
AUDIT_CMD="$SCRIPT_DIR/audit-loop --max $AUDIT_MAX"
[ -n "$MODEL" ] && AUDIT_CMD="$AUDIT_CMD --model $MODEL"
[ -n "$EFFORT" ] && AUDIT_CMD="$AUDIT_CMD --effort $EFFORT"
[ -n "$TIMEOUT" ] && AUDIT_CMD="$AUDIT_CMD --timeout $TIMEOUT"
$AUDIT_CMD && AUDIT_EXIT=0 || AUDIT_EXIT=$?

echo ""
echo "[$(date '+%H:%M:%S')] Audit phase finished (exit: $AUDIT_EXIT)"
echo ""

# Exit code 1 = actual error, exit code 2 = max iterations (continue anyway)
if [ $AUDIT_EXIT -eq 1 ]; then
  echo "Audit failed. Stopping."
  exit 1
fi

if [ ! -f "./audit-report.md" ]; then
  echo "No audit-report.md found. Stopping."
  exit 1
fi

# Phase 2: Verify
if [ "$SKIP_VERIFY" = false ]; then
  echo "[$(date '+%H:%M:%S')] Phase 2: VERIFY"
  echo ""
  VERIFY_CMD="$SCRIPT_DIR/audit-verify"
  [ -n "$MODEL" ] && VERIFY_CMD="$VERIFY_CMD --model $MODEL"
  [ -n "$EFFORT" ] && VERIFY_CMD="$VERIFY_CMD --effort $EFFORT"
  [ -n "$TIMEOUT" ] && VERIFY_CMD="$VERIFY_CMD --timeout $TIMEOUT"
  $VERIFY_CMD && VERIFY_EXIT=0 || VERIFY_EXIT=$?

  echo ""
  echo "[$(date '+%H:%M:%S')] Verify phase finished (exit: $VERIFY_EXIT)"
  echo ""
fi

# Phase 3: Fix
echo "[$(date '+%H:%M:%S')] Phase 3: FIX"
echo ""
FIX_CMD="$SCRIPT_DIR/audit-fix --max $FIX_MAX"
[ -n "$COMMIT_FLAG" ] && FIX_CMD="$FIX_CMD --commit"
[ -n "$MODEL" ] && FIX_CMD="$FIX_CMD --model $MODEL"
[ -n "$EFFORT" ] && FIX_CMD="$FIX_CMD --effort $EFFORT"
[ -n "$TIMEOUT" ] && FIX_CMD="$FIX_CMD --timeout $TIMEOUT"
$FIX_CMD && FIX_EXIT=0 || FIX_EXIT=$?

END_TIME=$(date +%s)
ELAPSED=$(( END_TIME - START_TIME ))
ELAPSED_MIN=$(( ELAPSED / 60 ))
ELAPSED_SEC=$(( ELAPSED % 60 ))

echo ""
echo "================================================"
echo "  [$(date '+%H:%M:%S')] Pipeline complete (${ELAPSED_MIN}m${ELAPSED_SEC}s)"
echo "  Reports:"
echo "    audit-report.md            Findings"
if [ "$SKIP_VERIFY" = false ]; then
  echo "    audit-report-verified.md   Verified findings"
fi
echo "    audit-fix-changelog.md     Fixes applied"
echo "================================================"
