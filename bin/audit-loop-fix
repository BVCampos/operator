#!/bin/bash
# audit-loop-fix — Run audit-loop, audit-verify, then audit-fix in sequence
# Usage: audit-loop-fix [--max N] [--audit-max N] [--verify-max N] [--fix-max N] [--skip-verify]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Defaults
AUDIT_MAX=10
VERIFY_MAX=10
FIX_MAX=10
SKIP_VERIFY=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --max)
      AUDIT_MAX="$2"
      VERIFY_MAX="$2"
      FIX_MAX="$2"
      shift 2
      ;;
    --audit-max)
      AUDIT_MAX="$2"
      shift 2
      ;;
    --verify-max)
      VERIFY_MAX="$2"
      shift 2
      ;;
    --fix-max)
      FIX_MAX="$2"
      shift 2
      ;;
    --skip-verify)
      SKIP_VERIFY=true
      shift
      ;;
    -h|--help)
      echo "Usage: audit-loop-fix [--max N] [--audit-max N] [--verify-max N] [--fix-max N] [--skip-verify]"
      echo ""
      echo "Runs audit-loop → audit-verify → audit-fix in sequence."
      echo ""
      echo "Options:"
      echo "  --max N          Set all three max values (default: 10)"
      echo "  --audit-max N    Max audit iterations (default: 10)"
      echo "  --verify-max N   Max verify iterations (default: 10)"
      echo "  --fix-max N      Max fix iterations (default: 10)"
      echo "  --skip-verify    Skip the verification step"
      exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        AUDIT_MAX="$1"
        VERIFY_MAX="$1"
        FIX_MAX="$1"
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

echo "================================================"
echo "  Audit + Verify + Fix Pipeline"
echo "  Audit:  up to $AUDIT_MAX iterations"
if [ "$SKIP_VERIFY" = false ]; then
  echo "  Verify: up to $VERIFY_MAX iterations"
else
  echo "  Verify: skipped"
fi
echo "  Fix:    up to $FIX_MAX iterations"
echo "================================================"
echo ""

START_TIME=$(date +%s)

# Phase 1: Audit
echo "[$(date '+%H:%M:%S')] Phase 1: AUDIT"
echo ""
"$SCRIPT_DIR/audit-loop" --max "$AUDIT_MAX"
AUDIT_EXIT=$?

echo ""
echo "[$(date '+%H:%M:%S')] Audit phase finished (exit: $AUDIT_EXIT)"
echo ""

if [ ! -f "./audit-report.md" ]; then
  echo "No audit-report.md found. Stopping."
  exit $AUDIT_EXIT
fi

# Phase 2: Verify
if [ "$SKIP_VERIFY" = false ]; then
  echo "[$(date '+%H:%M:%S')] Phase 2: VERIFY"
  echo ""
  "$SCRIPT_DIR/audit-verify" --max "$VERIFY_MAX"
  VERIFY_EXIT=$?

  echo ""
  echo "[$(date '+%H:%M:%S')] Verify phase finished (exit: $VERIFY_EXIT)"
  echo ""
fi

# Phase 3: Fix
echo "[$(date '+%H:%M:%S')] Phase 3: FIX"
echo ""
"$SCRIPT_DIR/audit-fix" --max "$FIX_MAX"
FIX_EXIT=$?

END_TIME=$(date +%s)
ELAPSED=$(( END_TIME - START_TIME ))
ELAPSED_MIN=$(( ELAPSED / 60 ))
ELAPSED_SEC=$(( ELAPSED % 60 ))

echo ""
echo "================================================"
echo "  [$(date '+%H:%M:%S')] Pipeline complete (${ELAPSED_MIN}m${ELAPSED_SEC}s)"
echo "  Reports:"
echo "    audit-report.md            Findings"
if [ "$SKIP_VERIFY" = false ]; then
  echo "    audit-report-verified.md   Verified findings"
fi
echo "    audit-fix-changelog.md     Fixes applied"
echo "================================================"
