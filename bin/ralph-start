#!/bin/bash
# ralph-start — Convert a PRD markdown, set up a worktree, and run Ralph autonomously
# Usage: ralph-start --prd <file.md> [--tool claude|amp] [--max N] [--name NAME]
#        ralph-start [--tool claude|amp] [--max N]  (if prd.json already exists in scripts/ralph/)

set -e

OPERATOR_STATE="$HOME/.operator"
RALPH_SRC="${RALPH_SRC:-$OPERATOR_STATE/ralph}"
SESSIONS_FILE="$OPERATOR_STATE/sessions.json"

# Lazy-clone ralph if needed
if [ ! -d "$RALPH_SRC" ]; then
  echo "Ralph not found. Cloning snarktank/ralph..."
  git clone https://github.com/snarktank/ralph.git "$RALPH_SRC" 2>/dev/null || {
    echo "Error: Could not clone ralph."
    echo "Set RALPH_SRC to a local ralph clone: export RALPH_SRC=~/path/to/ralph"
    exit 1
  }
fi

log() {
  local msg="[$(date '+%H:%M:%S')] $1"
  echo "$msg"
}

spin() {
  local pid=$1
  local label=$2
  local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local i=0
  local start=$SECONDS
  while kill -0 "$pid" 2>/dev/null; do
    local elapsed=$(( SECONDS - start ))
    local mins=$(( elapsed / 60 ))
    local secs=$(( elapsed % 60 ))
    printf "\r  %s %s (%dm%02ds)" "${chars:i++%${#chars}:1}" "$label" "$mins" "$secs"
    sleep 0.1
  done
  local total=$(( SECONDS - start ))
  local mins=$(( total / 60 ))
  local secs=$(( total % 60 ))
  printf "\r  ✓ %s completed (%dm%02ds)\n" "$label" "$mins" "$secs"
}

# Defaults
PRD_FILE=""
TOOL="claude"
MAX_ITERATIONS=10
NAME=""
PROJECT_DIR="$PWD"

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --prd)
      PRD_FILE="$(realpath "$2")"
      shift 2
      ;;
    --tool)
      TOOL="$2"
      shift 2
      ;;
    --max)
      MAX_ITERATIONS="$2"
      shift 2
      ;;
    --name)
      NAME="$2"
      shift 2
      ;;
    -h|--help)
      echo "Usage: ralph-start --prd <file.md> [--tool claude|amp] [--max N] [--name NAME]"
      echo ""
      echo "Options:"
      echo "  --prd FILE    Markdown PRD to convert to prd.json (required for first run)"
      echo "  --tool TOOL   AI tool to use: claude (default) or amp"
      echo "  --max N       Max iterations (default: 10)"
      echo "  --name NAME   Session name (default: derived from PRD filename)"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Validate we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: Not inside a git repository. cd into your project first."
  exit 1
fi

# Get the git root (in case we're in a subdirectory)
PROJECT_DIR="$(git rev-parse --show-toplevel)"

# Check prerequisites
for cmd in jq tmux; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is required. Install with: brew install $cmd"
    exit 1
  fi
done

if [[ "$TOOL" == "claude" ]] && ! command -v claude &>/dev/null; then
  echo "Error: claude CLI is required. Install with: npm install -g @anthropic-ai/claude-code"
  exit 1
fi

if [[ "$TOOL" == "amp" ]] && ! command -v amp &>/dev/null; then
  echo "Error: amp CLI is required."
  exit 1
fi

# Initialize ralph-ctl state directory
mkdir -p "$OPERATOR_STATE/logs"
if [ ! -f "$SESSIONS_FILE" ]; then
  echo "[]" > "$SESSIONS_FILE"
fi

# Derive session name from PRD filename if not provided
if [ -z "$NAME" ]; then
  if [ -n "$PRD_FILE" ]; then
    NAME="$(basename "$PRD_FILE" .md | sed 's/^prd-//')"
  else
    echo "Error: --name is required when not using --prd"
    exit 1
  fi
fi

# Sanitize name for use in branch/tmux session names
NAME="$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')"

WORKTREE_DIR="$PROJECT_DIR/.ralph-worktrees/$NAME"
BRANCH_NAME="ralph/$NAME"
SESSION_ID="ralph-$NAME"
LOG_FILE="$OPERATOR_STATE/logs/$SESSION_ID.log"

echo ""
echo "================================================"
log "ralph-start"
log "  Project:  $PROJECT_DIR"
log "  Name:     $NAME"
log "  Branch:   $BRANCH_NAME"
log "  Tool:     $TOOL"
log "  Max iter: $MAX_ITERATIONS"
[ -n "$PRD_FILE" ] && log "  PRD:      $PRD_FILE"
echo "================================================"
echo ""

# Check if session already exists
if tmux has-session -t "$SESSION_ID" 2>/dev/null; then
  log "Error: Session '$SESSION_ID' is already running."
  echo "Use 'ralph-logs $NAME' to view it, or 'ralph-stop $NAME' to stop it."
  exit 1
fi

# Check if worktree already exists
if [ -d "$WORKTREE_DIR" ]; then
  log "Worktree already exists at $WORKTREE_DIR — reusing."
else
  log "Creating worktree at $WORKTREE_DIR on branch $BRANCH_NAME..."

  # Check if branch already exists
  if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME" 2>/dev/null; then
    git worktree add "$WORKTREE_DIR" "$BRANCH_NAME"
  else
    git worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR"
  fi
fi

# Set up ralph files in worktree
RALPH_DEST="$WORKTREE_DIR/scripts/ralph"
mkdir -p "$RALPH_DEST"

# Copy ralph.sh and prompt files if not already there
for file in ralph.sh CLAUDE.md prompt.md; do
  if [ ! -f "$RALPH_DEST/$file" ] && [ -f "$RALPH_SRC/$file" ]; then
    cp "$RALPH_SRC/$file" "$RALPH_DEST/"
  fi
done
chmod +x "$RALPH_DEST/ralph.sh"

# Convert PRD if provided
if [ -n "$PRD_FILE" ]; then
  if [ ! -f "$PRD_FILE" ]; then
    echo "Error: PRD file not found: $PRD_FILE"
    exit 1
  fi

  log "Converting PRD to prd.json..."
  log "PRD source: $PRD_FILE ($(wc -l < "$PRD_FILE" | tr -d ' ') lines)"

  # Build the conversion prompt
  CONVERT_PROMPT="$(cat <<'PROMPT_EOF'
You are a PRD-to-JSON converter. Convert the following markdown PRD into the exact prd.json format that Ralph uses.

Output ONLY valid JSON, no markdown fences, no explanation.

The JSON format must be:
{
  "project": "[Project Name]",
  "branchName": "BRANCH_PLACEHOLDER",
  "description": "[Feature description]",
  "userStories": [
    {
      "id": "US-001",
      "title": "[Story title]",
      "description": "As a [user], I want [feature] so that [benefit]",
      "acceptanceCriteria": ["Criterion 1", "Criterion 2", "Typecheck passes"],
      "priority": 1,
      "passes": false,
      "notes": ""
    }
  ]
}

Rules:
- Each story must be small enough for ONE context window (one Ralph iteration)
- Order by dependency: schema/DB first, then backend, then UI
- Every story MUST have "Typecheck passes" as acceptance criterion
- UI stories MUST also have "Verify in browser using dev-browser skill"
- All stories start with passes: false and empty notes
- IDs are sequential: US-001, US-002, etc.
- If stories are too large, split them

Here is the PRD to convert:

PROMPT_EOF
)"

  # Replace branch placeholder
  CONVERT_PROMPT="${CONVERT_PROMPT//BRANCH_PLACEHOLDER/$BRANCH_NAME}"

  # Append the actual PRD content
  PRD_CONTENT="$(cat "$PRD_FILE")"
  FULL_PROMPT="$CONVERT_PROMPT
$PRD_CONTENT"

  # Run claude to convert (with spinner)
  CONVERT_OUT=$(mktemp)
  echo "$FULL_PROMPT" | command claude --print > "$CONVERT_OUT" 2>&1 &
  CLAUDE_PID=$!
  log "Claude conversion started (PID: $CLAUDE_PID)"
  spin $CLAUDE_PID "Converting PRD to JSON"
  wait $CLAUDE_PID || true
  RESULT=$(cat "$CONVERT_OUT")
  rm -f "$CONVERT_OUT"

  # Extract JSON (in case claude wraps it in markdown fences)
  JSON_RESULT=$(echo "$RESULT" | sed -n '/^{/,/^}/p')

  if [ -z "$JSON_RESULT" ]; then
    # Try stripping markdown fences
    JSON_RESULT=$(echo "$RESULT" | sed '1{/^```/d}' | sed '${/^```/d}' | sed -n '/^{/,/^}/p')
  fi

  # Validate JSON
  if ! echo "$JSON_RESULT" | jq . &>/dev/null; then
    echo "Error: Failed to produce valid JSON from PRD conversion."
    echo "Raw output:"
    echo "$RESULT"
    exit 1
  fi

  # Ensure branchName is correct
  JSON_RESULT=$(echo "$JSON_RESULT" | jq --arg branch "$BRANCH_NAME" '.branchName = $branch')

  # Write prd.json
  echo "$JSON_RESULT" | jq . > "$RALPH_DEST/prd.json"
  STORY_COUNT=$(echo "$JSON_RESULT" | jq '.userStories | length')
  log "Created prd.json with $STORY_COUNT user stories."
  echo ""
  log "Stories:"
  echo "$JSON_RESULT" | jq -r '.userStories[] | "  \(.id): \(.title) (priority: \(.priority))"'
  echo ""

elif [ ! -f "$RALPH_DEST/prd.json" ]; then
  echo "Error: No prd.json found and no --prd file provided."
  echo "Use --prd <file.md> to convert a PRD, or place prd.json in $RALPH_DEST/"
  exit 1
fi

# Create the wrapper script that runs ralph.sh and handles PR creation on completion
WRAPPER_SCRIPT="$RALPH_DEST/.ralph-runner.sh"
cat > "$WRAPPER_SCRIPT" <<'RUNNER_HEADER'
#!/bin/bash
set -e

rlog() {
  echo "[$(date '+%H:%M:%S')] $1"
}
RUNNER_HEADER

cat >> "$WRAPPER_SCRIPT" <<RUNNER_EOF

cd "$WORKTREE_DIR"

echo "================================================"
rlog "Ralph starting"
rlog "  Worktree: $WORKTREE_DIR"
rlog "  Branch:   $BRANCH_NAME"
rlog "  Tool:     $TOOL"
rlog "  Max iter: $MAX_ITERATIONS"

# Show stories from prd.json
TOTAL=\$(jq '.userStories | length' "$RALPH_DEST/prd.json" 2>/dev/null || echo "?")
DONE=\$(jq '[.userStories[] | select(.passes == true)] | length' "$RALPH_DEST/prd.json" 2>/dev/null || echo "0")
rlog "  Stories:  \$DONE/\$TOTAL complete"
echo "================================================"
echo ""

START_TIME=\$(date +%s)

# Run ralph
"$RALPH_DEST/ralph.sh" --tool "$TOOL" "$MAX_ITERATIONS"
EXIT_CODE=\$?

END_TIME=\$(date +%s)
ELAPSED=\$(( END_TIME - START_TIME ))
ELAPSED_MIN=\$(( ELAPSED / 60 ))
ELAPSED_SEC=\$(( ELAPSED % 60 ))

echo ""
echo "================================================"
rlog "Total time: \${ELAPSED_MIN}m\${ELAPSED_SEC}s"

# Show final story status
DONE=\$(jq '[.userStories[] | select(.passes == true)] | length' "$RALPH_DEST/prd.json" 2>/dev/null || echo "?")
rlog "Stories completed: \$DONE/\$TOTAL"

if [ \$EXIT_CODE -eq 0 ]; then
  rlog "Ralph completed all tasks! Creating PR..."

  # Push the branch
  git push -u origin "$BRANCH_NAME" 2>/dev/null || git push origin "$BRANCH_NAME"
  rlog "Pushed branch $BRANCH_NAME"

  # Get PR description from prd.json
  DESCRIPTION=\$(jq -r '.description // "Ralph automated implementation"' "$RALPH_DEST/prd.json")
  STORIES=\$(jq -r '.userStories[] | "- [x] \(.id): \(.title)"' "$RALPH_DEST/prd.json")

  # Create PR
  rlog "Creating PR..."
  gh pr create \
    --title "feat: \$DESCRIPTION" \
    --body "\$(cat <<PR_EOF
## Summary

\$DESCRIPTION

## Stories Completed

\$STORIES

## Notes

- Implemented autonomously by Ralph (\$TOOL, completed in \${ELAPSED_MIN}m\${ELAPSED_SEC}s)
- Review progress.txt for iteration details

---
*Generated by ralph-ctl*
PR_EOF
)" 2>&1 || rlog "Warning: Could not create PR. Push may have failed or PR already exists."

  rlog "PR created. Run 'ralph-clean $NAME' after merging."
else
  rlog "Ralph did not complete all tasks (\$DONE/\$TOTAL stories)."
  rlog "Check logs: ralph-logs $NAME"
  rlog "Retry: ralph-stop $NAME && ralph-start --name $NAME --tool $TOOL --max $MAX_ITERATIONS"
fi

echo ""
rlog "Session complete. Detach with Ctrl+B then D. Close with 'exit'."
exec bash
RUNNER_EOF
chmod +x "$WRAPPER_SCRIPT"

# Start tmux session
log "Launching Ralph in tmux session: $SESSION_ID"
tmux new-session -d -s "$SESSION_ID" -c "$WORKTREE_DIR" \
  "script -q '$LOG_FILE' '$WRAPPER_SCRIPT' 2>&1"

# Verify tmux session started
sleep 0.5
if tmux has-session -t "$SESSION_ID" 2>/dev/null; then
  log "tmux session started successfully"
else
  log "Error: tmux session failed to start"
  exit 1
fi

# Register session
TIMESTAMP="$(date -Iseconds)"
jq --arg id "$SESSION_ID" \
   --arg name "$NAME" \
   --arg project "$PROJECT_DIR" \
   --arg worktree "$WORKTREE_DIR" \
   --arg branch "$BRANCH_NAME" \
   --arg tool "$TOOL" \
   --arg max "$MAX_ITERATIONS" \
   --arg prd "${PRD_FILE:-}" \
   --arg time "$TIMESTAMP" \
   --arg log "$LOG_FILE" \
   '. + [{
     "id": $id,
     "name": $name,
     "project": $project,
     "worktree": $worktree,
     "branch": $branch,
     "tool": $tool,
     "max_iterations": $max,
     "prd_source": $prd,
     "started": $time,
     "log": $log
   }]' "$SESSIONS_FILE" > "${SESSIONS_FILE}.tmp" && mv "${SESSIONS_FILE}.tmp" "$SESSIONS_FILE"

echo ""
log "Ralph is running!"
log "  Session:   $SESSION_ID"
log "  Worktree:  $WORKTREE_DIR"
log "  Branch:    $BRANCH_NAME"
log "  Log:       $LOG_FILE"
echo ""
echo "Commands:"
echo "  ralph-status          List all sessions"
echo "  ralph-logs $NAME     Attach to live output (Ctrl+B D to detach)"
echo "  ralph-stop $NAME     Stop the loop"
echo "  ralph-clean $NAME    Remove worktree after merge"
