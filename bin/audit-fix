#!/bin/bash
# audit-fix — Fix audit findings in parallel using worktrees
# Usage: audit-fix [--max N] [--model MODEL] [--effort LEVEL]

set -e

OPERATOR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROMPTS_DIR="$OPERATOR_DIR/prompts"
FIX_PROMPT="$PROMPTS_DIR/audit-fix-phase.md"
REPAIR_PROMPT="$PROMPTS_DIR/audit-fix-repair-phase.md"

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"
setup_log "audit-fix"

# Defaults
MAX_SECTIONS=0  # 0 = all unfixed
MAX_REPAIRS=3
NO_COMMIT=true
NO_REPAIR=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  if try_parse_common "$@"; then
    shift $PARSED_SHIFT
    continue
  fi
  case $1 in
    --commit)
      NO_COMMIT=false
      shift
      ;;
    --no-repair)
      NO_REPAIR=true
      shift
      ;;
    --max-repairs)
      MAX_REPAIRS="$2"
      shift 2
      ;;
    --max)
      MAX_SECTIONS="$2"
      shift 2
      ;;
    -h|--help)
      echo "Usage: audit-fix [--max N] [--model MODEL] [--effort LEVEL] [--timeout MIN]"
      echo ""
      echo "Fixes audit findings in parallel — one worktree per section."
      echo "Cherry-picks commits back, runs checks, and auto-repairs any breakages."
      echo ""
      echo "Options:"
      echo "  --commit         Commit fixes automatically (default: no commit, changes left staged)"
      echo "  --max N          Max sections to fix in parallel (default: all)"
      echo "  --model MODEL    Claude model to use (e.g., sonnet)"
      echo "  --effort LEVEL   Thinking effort: low, medium, high, max"
      echo "  --timeout MIN    Kill claude after MIN minutes with no output (default: 15)"
      echo "  --no-repair      Skip the auto-repair phase if checks fail"
      echo "  --max-repairs N  Max repair iterations (default: 3)"
      exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        MAX_SECTIONS="$1"
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

validate_env
build_claude_cmd

BASE_BRANCH=$(git branch --show-current)
BASE_COMMIT=$(git rev-parse HEAD)

# Prefer verified report
if [ -f "$PROJECT_DIR/audit-report-verified.md" ]; then
  REPORT_FILE="$PROJECT_DIR/audit-report-verified.md"
  log "Using verified report: audit-report-verified.md"
elif [ -f "$PROJECT_DIR/audit-report.md" ]; then
  REPORT_FILE="$PROJECT_DIR/audit-report.md"
  log "Using unverified report: audit-report.md"
else
  echo "Error: No audit report found. Run 'operator audit' first."
  exit 1
fi

PROGRESS_FILE="$PROJECT_DIR/audit-fix-progress.md"
CHANGELOG_FILE="$PROJECT_DIR/audit-fix-changelog.md"

# ── Extract sections from report ────────────────────────────────────

ALL_SECTIONS=()
while IFS= read -r line; do
  ALL_SECTIONS+=("$(echo "$line" | sed 's/^## //' | sed 's/ — .*//')")
done < <(grep "^## " "$REPORT_FILE")

ALL_COUNT=${#ALL_SECTIONS[@]}

if [ "$ALL_COUNT" -eq 0 ]; then
  echo "Error: No sections found in audit report."
  exit 1
fi

# ── Filter to unfixed sections ──────────────────────────────────────

SECTIONS=()
if [ -f "$PROGRESS_FILE" ]; then
  for section in "${ALL_SECTIONS[@]}"; do
    if ! grep -F "[x]" "$PROGRESS_FILE" 2>/dev/null | grep -qF "$section"; then
      SECTIONS+=("$section")
    fi
  done
else
  SECTIONS=("${ALL_SECTIONS[@]}")
fi

SECTION_COUNT=${#SECTIONS[@]}

if [ "$SECTION_COUNT" -eq 0 ]; then
  log "All sections already fixed!"
  exit 0
fi

# Apply max limit
if [ "$MAX_SECTIONS" -gt 0 ] && [ "$MAX_SECTIONS" -lt "$SECTION_COUNT" ]; then
  SECTIONS=("${SECTIONS[@]:0:$MAX_SECTIONS}")
  SECTION_COUNT=${#SECTIONS[@]}
fi

echo "================================================"
echo "  Audit Fix — $SECTION_COUNT sections in parallel"
[ -n "$MODEL" ] && echo "  Model:    $MODEL"
[ -n "$EFFORT" ] && echo "  Effort:   $EFFORT"
echo "  Stall:    kill after ${CLAUDE_TIMEOUT}m with no output"
[ "$NO_REPAIR" = true ] && echo "  Repair:   disabled"
[ "$NO_COMMIT" = false ] && echo "  Commit:   enabled"
echo "  Project:  $PROJECT_DIR"
echo "  Branch:   $BASE_BRANCH"
echo "  Report:   $(basename "$REPORT_FILE")"
echo "  Log:      $LOG_FILE"
echo "================================================"
echo ""
log "Started audit-fix — $SECTION_COUNT sections in parallel"
log "Base commit: $BASE_COMMIT"

# ── Set up worktrees and launch fixers ──────────────────────────────

FIX_TEMPLATE=$(cat "$FIX_PROMPT")
WORK_DIR=$(mktemp -d)
WORKTREE_BASE="$PROJECT_DIR/.audit-fix-worktrees"
mkdir -p "$WORKTREE_BASE"

SANITIZED_NAMES=()

cleanup() {
  cd "$PROJECT_DIR" 2>/dev/null || true
  for name in "${SANITIZED_NAMES[@]}"; do
    git worktree remove "$WORKTREE_BASE/$name" --force 2>/dev/null || rm -rf "$WORKTREE_BASE/$name"
    git branch -D "audit-fix/$name" 2>/dev/null || true
  done
  rmdir "$WORKTREE_BASE" 2>/dev/null || true
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

START_TIME=$(date +%s)
PIDS=()

for i in "${!SECTIONS[@]}"; do
  section="${SECTIONS[$i]}"
  idx=$((i + 1))

  name=$(sanitize_name "$section")
  SANITIZED_NAMES+=("$name")

  branch="audit-fix/$name"
  wt="$WORKTREE_BASE/$name"

  # Clean up if exists from previous run
  [ -d "$wt" ] && { git worktree remove "$wt" --force 2>/dev/null || rm -rf "$wt"; }
  git branch -D "$branch" 2>/dev/null || true

  # Create worktree from current HEAD
  git worktree add -b "$branch" "$wt" "$BASE_COMMIT" --quiet

  # Symlink node_modules for tsc (avoids duplicate installs)
  [ -d "$PROJECT_DIR/node_modules" ] && [ ! -e "$wt/node_modules" ] && \
    ln -s "$PROJECT_DIR/node_modules" "$wt/node_modules"

  # Copy audit report into worktree (may not be in git)
  cp "$REPORT_FILE" "$wt/$(basename "$REPORT_FILE")" 2>/dev/null || true

  SECTION_CONTENT=$(extract_section "$REPORT_FILE" "$section")

  # Build per-section prompt
  cat > "$WORK_DIR/prompt-$idx.md" <<PROMPT_EOF
$FIX_TEMPLATE

---

## Section to fix (${idx} of ${SECTION_COUNT})

**Section name:** $section

### Findings to fix

$SECTION_CONTENT
PROMPT_EOF

  # Launch Claude in the worktree
  (cd "$wt" && command $CLAUDE_CMD < "$WORK_DIR/prompt-$idx.md" > "$WORK_DIR/output-$idx.md" 2>&1) &
  PIDS+=($!)

  log "  Launched fixer $idx/$SECTION_COUNT: $section (PID: $!)"
done

echo ""

# ── Wait with combined spinner ──────────────────────────────────────

spin_all "Fixing findings" "$WORK_DIR" "${PIDS[@]}"

FAILURES=0
for pid in "${PIDS[@]}"; do
  wait "$pid" 2>/dev/null || FAILURES=$((FAILURES + 1))
done

echo ""
[ "$SPIN_TIMED_OUT" = true ] && log "Warning: fix phase stalled (no output for ${CLAUDE_TIMEOUT}m) — some sections may be incomplete"
[ $FAILURES -gt 0 ] && log "Warning: $FAILURES section(s) had errors"

# ── Cherry-pick commits back to main branch ─────────────────────────

log "Merging fixes to $BASE_BRANCH..."

MERGED_SECTIONS=()
CONFLICT_SECTIONS=()

for i in "${!SECTIONS[@]}"; do
  section="${SECTIONS[$i]}"
  name="${SANITIZED_NAMES[$i]}"
  branch="audit-fix/$name"

  COMMIT_COUNT=$(git log --oneline "$BASE_COMMIT..$branch" 2>/dev/null | wc -l | tr -d ' ')

  if [ "$COMMIT_COUNT" -eq 0 ]; then
    log "  ✗ $section: no commits"
    continue
  fi

  COMMITS=$(git log --reverse --format="%H" "$BASE_COMMIT..$branch" 2>/dev/null)

  ok=true
  CP_FLAGS="--no-edit"
  [ "$NO_COMMIT" = true ] && CP_FLAGS="$CP_FLAGS --no-commit"
  for commit in $COMMITS; do
    if ! git cherry-pick $CP_FLAGS "$commit" 2>/dev/null; then
      git cherry-pick --abort 2>/dev/null || true
      CONFLICT_SECTIONS+=("$section")
      ok=false
      break
    fi
  done

  if [ "$ok" = true ]; then
    MERGED_SECTIONS+=("$section")
    log "  ✓ $section ($COMMIT_COUNT commits)"
  else
    log "  ✗ $section (conflict, skipped)"
  fi
done

MERGED=${#MERGED_SECTIONS[@]}

echo ""
log "Merged: $MERGED/$SECTION_COUNT sections"
[ ${#CONFLICT_SECTIONS[@]} -gt 0 ] && log "Conflicts: ${CONFLICT_SECTIONS[*]}"

# ── Show fix summaries ──────────────────────────────────────────────

for i in "${!SECTIONS[@]}"; do
  idx=$((i + 1))
  section="${SECTIONS[$i]}"
  if [ -f "$WORK_DIR/output-$idx.md" ] && [ -s "$WORK_DIR/output-$idx.md" ]; then
    echo ""
    log "--- $section ---"
    cat "$WORK_DIR/output-$idx.md"
    cat "$WORK_DIR/output-$idx.md" >> "$LOG_FILE"
  fi
done

# ── Run checks on the combined result ─────────────────────────────

TSC_OK=true
LINT_OK=true
FORMAT_OK=true
TESTS_OK=true
ALL_CHECKS_OK=true
CHECK_ERRORS=""
REPAIR_ITERATION=0

run_checks() {
  TSC_OK=true; LINT_OK=true; FORMAT_OK=true; TESTS_OK=true
  CHECK_ERRORS=""

  echo ""
  log "Running verification on combined result..."

  run_check "Type checking" "tsc" "npx tsc --noEmit" && TSC_OK=true || TSC_OK=false

  if (cd "$PROJECT_DIR" && npx eslint --version &>/dev/null); then
    run_check "Linting (eslint)" "lint" "npx eslint ." 50 && LINT_OK=true || LINT_OK=false
  elif (cd "$PROJECT_DIR" && npx biome --version &>/dev/null); then
    run_check "Linting (biome)" "lint" "npx biome check ." 50 && LINT_OK=true || LINT_OK=false
  else
    log "  lint: no linter found, skipping"
  fi

  if (cd "$PROJECT_DIR" && npx prettier --version &>/dev/null); then
    run_check "Format check (prettier)" "format" "npx prettier --check ." 30 && FORMAT_OK=true || FORMAT_OK=false
  elif (cd "$PROJECT_DIR" && npx biome --version &>/dev/null) && [ "$LINT_OK" != false ]; then
    run_check "Format check (biome)" "format" "npx biome format ." 30 && FORMAT_OK=true || FORMAT_OK=false
  else
    log "  format: no formatter found, skipping"
  fi

  run_check "Running tests" "tests" "npm test" 50 && TESTS_OK=true || TESTS_OK=false

  if [ "$TSC_OK" = true ] && [ "$LINT_OK" = true ] && [ "$FORMAT_OK" = true ] && [ "$TESTS_OK" = true ]; then
    ALL_CHECKS_OK=true
  else
    ALL_CHECKS_OK=false
  fi
}

if [ "$MERGED" -gt 0 ] && [ -f "$PROJECT_DIR/package.json" ]; then
  run_checks

  # ── Auto-repair loop ────────────────────────────────────────────────

  if [ "$ALL_CHECKS_OK" = false ] && [ "$NO_REPAIR" = false ]; then
    REPAIR_TEMPLATE=$(cat "$REPAIR_PROMPT")

    while [ "$ALL_CHECKS_OK" = false ] && [ "$REPAIR_ITERATION" -lt "$MAX_REPAIRS" ]; do
      REPAIR_ITERATION=$((REPAIR_ITERATION + 1))
      echo ""
      log "Repair iteration $REPAIR_ITERATION/$MAX_REPAIRS — launching Claude to fix breakages..."

      REPAIR_INPUT=$(mktemp)
      cat > "$REPAIR_INPUT" <<REPAIR_EOF
$REPAIR_TEMPLATE

---

## Failing checks (repair iteration $REPAIR_ITERATION)

$CHECK_ERRORS
REPAIR_EOF

      run_claude "$REPAIR_INPUT" "Repairing (iteration $REPAIR_ITERATION)" || true
      if [ -n "$CLAUDE_OUTPUT" ]; then
        log "--- Repair output (iteration $REPAIR_ITERATION) ---"
        echo "$CLAUDE_OUTPUT"
        echo "$CLAUDE_OUTPUT" >> "$LOG_FILE"
      fi
      rm -f "$REPAIR_INPUT"

      # Re-run checks
      run_checks
    done

    if [ "$ALL_CHECKS_OK" = false ]; then
      log "Warning: checks still failing after $MAX_REPAIRS repair iterations"
    else
      log "Repair successful after $REPAIR_ITERATION iteration(s)"
    fi
  fi
fi

# ── Update progress and changelog ───────────────────────────────────

# Create progress file if needed
if [ ! -f "$PROGRESS_FILE" ]; then
  {
    echo "# Audit Fix Progress"
    echo ""
    echo "## Sections"
    for section in "${ALL_SECTIONS[@]}"; do
      echo "- [ ] $section"
    done
  } > "$PROGRESS_FILE"
fi

# Mark merged sections as fixed
for section in "${MERGED_SECTIONS[@]}"; do
  TEMP_PF=$(mktemp)
  while IFS= read -r line; do
    if echo "$line" | grep -qF "[ ] $section"; then
      echo "- [x] $section — Fixed $(date '+%Y-%m-%d')"
    else
      echo "$line"
    fi
  done < "$PROGRESS_FILE" > "$TEMP_PF"
  mv "$TEMP_PF" "$PROGRESS_FILE"
done

# Append to changelog
if [ ! -f "$CHANGELOG_FILE" ]; then
  echo "# Audit Fix Changelog" > "$CHANGELOG_FILE"
  echo "" >> "$CHANGELOG_FILE"
fi

{
  echo "## Parallel Fix — $(date '+%Y-%m-%d %H:%M')"
  echo ""
  echo "Sections fixed: $MERGED/$SECTION_COUNT"
  [ ${#CONFLICT_SECTIONS[@]} -gt 0 ] && echo "Conflicts (skipped): ${CONFLICT_SECTIONS[*]}"
  echo ""

  for i in "${!SECTIONS[@]}"; do
    idx=$((i + 1))
    section="${SECTIONS[$i]}"
    if [ -f "$WORK_DIR/output-$idx.md" ] && [ -s "$WORK_DIR/output-$idx.md" ]; then
      echo "### $section"
      echo ""
      cat "$WORK_DIR/output-$idx.md"
      echo ""
    fi
  done

  echo "### Verification"
  echo "- tsc: $([ "$TSC_OK" = true ] && echo "clean" || echo "errors")"
  echo "- lint: $([ "$LINT_OK" = true ] && echo "clean" || echo "errors")"
  echo "- format: $([ "$FORMAT_OK" = true ] && echo "clean" || echo "errors")"
  echo "- tests: $([ "$TESTS_OK" = true ] && echo "passing" || echo "failures")"
  [ "$REPAIR_ITERATION" -gt 0 ] && echo "- repair: $REPAIR_ITERATION iteration(s), $([ "$ALL_CHECKS_OK" = true ] && echo "fixed" || echo "still failing")"
  echo ""
  echo "---"
  echo ""
} >> "$CHANGELOG_FILE"

# Commit progress + changelog (only if --commit)
git add "$PROGRESS_FILE" "$CHANGELOG_FILE" 2>/dev/null || true
if [ "$NO_COMMIT" = false ]; then
  git commit -m "docs(audit): update fix progress and changelog" 2>/dev/null || true
fi

ELAPSED=$(( $(date +%s) - START_TIME ))

echo ""
log "================================================"
log "  Audit Fix complete! ($(format_elapsed $ELAPSED))"
log "  Sections fixed: $MERGED/$SECTION_COUNT"
[ ${#CONFLICT_SECTIONS[@]} -gt 0 ] && log "  Conflicts:      ${CONFLICT_SECTIONS[*]}"
[ "$MERGED" -gt 0 ] && log "  tsc:            $([ "$TSC_OK" = true ] && echo "clean" || echo "errors")"
[ "$MERGED" -gt 0 ] && log "  lint:           $([ "$LINT_OK" = true ] && echo "clean" || echo "errors")"
[ "$MERGED" -gt 0 ] && log "  format:         $([ "$FORMAT_OK" = true ] && echo "clean" || echo "errors")"
[ "$MERGED" -gt 0 ] && log "  tests:          $([ "$TESTS_OK" = true ] && echo "passing" || echo "failures")"
[ "$REPAIR_ITERATION" -gt 0 ] && log "  repair:         $REPAIR_ITERATION iteration(s)"
log "  Progress:       $PROGRESS_FILE"
log "  Changelog:      $CHANGELOG_FILE"
log "================================================"
