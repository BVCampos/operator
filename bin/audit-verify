#!/bin/bash
# audit-verify — Verify all audit findings in parallel (one agent per section)
# Usage: audit-verify [--model MODEL] [--effort LEVEL]

set -e

OPERATOR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROMPTS_DIR="$OPERATOR_DIR/prompts"
VERIFY_PROMPT="$PROMPTS_DIR/audit-verify-phase.md"

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"
setup_log "audit-verify"

# Defaults
MODEL=""
EFFORT=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --max)
      echo "Note: --max is ignored. audit-verify runs all sections in one parallel pass."
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    --effort)
      EFFORT="$2"
      shift 2
      ;;
    -h|--help)
      echo "Usage: audit-verify [--model MODEL] [--effort LEVEL]"
      echo ""
      echo "Verifies all audit findings in parallel — one agent per section."
      echo "Run after 'operator audit', before 'operator audit fix'."
      echo ""
      echo "Options:"
      echo "  --model MODEL    Claude model to use (e.g., sonnet, opus)"
      echo "  --effort LEVEL   Thinking effort: low, medium, high, max"
      echo ""
      echo "Files:"
      echo "  audit-report.md            Input (required)"
      echo "  audit-report-verified.md   Output — findings with verdicts"
      exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        echo "Note: iteration count is ignored. audit-verify runs all sections in one parallel pass."
      else
        echo "Unknown option: $1"
        exit 1
      fi
      shift
      ;;
  esac
done

# Validate
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: Not inside a git repository."
  exit 1
fi

if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI is required."
  exit 1
fi

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

REPORT_FILE="$PROJECT_DIR/audit-report.md"
VERIFIED_FILE="$PROJECT_DIR/audit-report-verified.md"

if [ ! -f "$REPORT_FILE" ]; then
  echo "Error: No audit-report.md found."
  echo "Run 'operator audit' first to generate the audit report."
  exit 1
fi

# Extract section headings from audit report (lines like "## Section Name — Audited ...")
SECTIONS=()
while IFS= read -r line; do
  section_name=$(echo "$line" | sed 's/^## //' | sed 's/ — .*//')
  SECTIONS+=("$section_name")
done < <(grep "^## " "$REPORT_FILE")

SECTION_COUNT=${#SECTIONS[@]}

if [ "$SECTION_COUNT" -eq 0 ]; then
  echo "Error: No sections found in audit-report.md."
  exit 1
fi

REPORT_LINES=$(wc -l < "$REPORT_FILE" | tr -d ' ')

# Build claude command
CLAUDE_CMD="claude --dangerously-skip-permissions --print"
[ -n "$MODEL" ] && CLAUDE_CMD="$CLAUDE_CMD --model $MODEL"
[ -n "$EFFORT" ] && CLAUDE_CMD="$CLAUDE_CMD --effort $EFFORT"

echo "================================================"
echo "  Audit Verify — $SECTION_COUNT sections in parallel"
echo "  Project:  $PROJECT_DIR"
[ -n "$MODEL" ] && echo "  Model:    $MODEL"
[ -n "$EFFORT" ] && echo "  Effort:   $EFFORT"
echo "  Report:   $REPORT_FILE ($REPORT_LINES lines)"
echo "  Log:      $LOG_FILE"
echo "================================================"
echo ""
log "Started audit-verify — $SECTION_COUNT sections in parallel"

# Read the full report for cross-reference
REPORT_CONTENT=$(cat "$REPORT_FILE")

# Create temp directory for per-section prompts and outputs
WORK_DIR=$(mktemp -d)
trap "rm -rf '$WORK_DIR'" EXIT

# Read the verify prompt template
VERIFY_TEMPLATE=$(cat "$VERIFY_PROMPT")

START_TIME=$(date +%s)

# Launch one Claude instance per section
PIDS=()
for i in "${!SECTIONS[@]}"; do
  section="${SECTIONS[$i]}"
  idx=$((i + 1))

  # Extract this section's content from the report (from "## <section>" to next "## " or EOF)
  SECTION_CONTENT=$(awk -v header="## $section" '
    $0 == header || index($0, header " — ") == 1 { found=1; print; next }
    found && /^## / { exit }
    found { print }
  ' "$REPORT_FILE")

  # Build per-section prompt: template + section data
  cat > "$WORK_DIR/prompt-$idx.md" <<PROMPT_EOF
$VERIFY_TEMPLATE

---

## Section to verify (${idx} of ${SECTION_COUNT})

**Section name:** $section

### Findings to verify

$SECTION_CONTENT

### Full audit report (for cross-reference / duplicate checking)

$REPORT_CONTENT
PROMPT_EOF

  # Launch claude in background
  command $CLAUDE_CMD < "$WORK_DIR/prompt-$idx.md" > "$WORK_DIR/output-$idx.md" 2>&1 &
  PIDS+=($!)

  log "  Launched verifier $idx/$SECTION_COUNT: $section (PID: $!)"
done

echo ""

# Combined spinner showing progress across all parallel instances
spin_all() {
  # Non-TTY fallback (log files, pipes)
  if [ ! -t 1 ]; then
    echo "  Verifying findings — $# sections..."
    for pid in "$@"; do
      wait "$pid" 2>/dev/null || true
    done
    echo "  ✓ All sections verified"
    return
  fi

  local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local i=0
  local start=$SECONDS
  local total=$#

  while true; do
    local running=0
    for pid in "$@"; do
      kill -0 "$pid" 2>/dev/null && running=$((running + 1))
    done

    [ $running -eq 0 ] && break

    local elapsed=$(( SECONDS - start ))
    local mins=$(( elapsed / 60 ))
    local secs=$(( elapsed % 60 ))
    local done_count=$(( total - running ))
    printf "\033[2K\r  %s Verifying findings — %d/%d sections complete (%dm%02ds)" \
      "${chars:i++%${#chars}:1}" "$done_count" "$total" "$mins" "$secs"
    sleep 0.1
  done

  local total_time=$(( SECONDS - start ))
  local mins=$(( total_time / 60 ))
  local secs=$(( total_time % 60 ))
  printf "\033[2K\r  ✓ All %d sections verified (%dm%02ds)\n" "$total" "$mins" "$secs"
}

spin_all "${PIDS[@]}"

# Wait for all processes and collect exit codes
FAILURES=0
for pid in "${PIDS[@]}"; do
  wait "$pid" || FAILURES=$((FAILURES + 1))
done

echo ""
[ $FAILURES -gt 0 ] && log "Warning: $FAILURES section(s) had verification errors"

# Combine results into verified report
log "Combining verification results..."
{
  echo "# Codebase Audit Report — Verified"
  echo ""
  echo "Verified on $(date '+%Y-%m-%d %H:%M')"
  echo ""

  for i in "${!SECTIONS[@]}"; do
    idx=$((i + 1))
    section="${SECTIONS[$i]}"

    if [ -f "$WORK_DIR/output-$idx.md" ] && [ -s "$WORK_DIR/output-$idx.md" ]; then
      cat "$WORK_DIR/output-$idx.md"
      echo ""
      echo "---"
      echo ""

      CONFIRMED=$(grep -ci "CONFIRMED" "$WORK_DIR/output-$idx.md" 2>/dev/null) || CONFIRMED=0
      FALSE_POS=$(grep -ci "FALSE_POSITIVE" "$WORK_DIR/output-$idx.md" 2>/dev/null) || FALSE_POS=0
      log "  $section: $CONFIRMED confirmed, $FALSE_POS false positives"
    else
      log "  $section: no output (verification may have failed)"
    fi
  done
} > "$VERIFIED_FILE"

END_TIME=$(date +%s)
ELAPSED=$(( END_TIME - START_TIME ))
ELAPSED_MIN=$(( ELAPSED / 60 ))
ELAPSED_SEC=$(( ELAPSED % 60 ))

# Final stats
TOTAL_CONFIRMED=$(grep -ci "CONFIRMED" "$VERIFIED_FILE" 2>/dev/null) || TOTAL_CONFIRMED=0
TOTAL_FALSE_POS=$(grep -ci "FALSE_POSITIVE" "$VERIFIED_FILE" 2>/dev/null) || TOTAL_FALSE_POS=0
TOTAL_DUPES=$(grep -ci "DUPLICATE" "$VERIFIED_FILE" 2>/dev/null) || TOTAL_DUPES=0
TOTAL_BY_DESIGN=$(grep -ci "BY_DESIGN" "$VERIFIED_FILE" 2>/dev/null) || TOTAL_BY_DESIGN=0

echo ""
log "================================================"
log "  Verification COMPLETE! (${ELAPSED_MIN}m${ELAPSED_SEC}s)"
log "  Sections verified: $SECTION_COUNT"
log "  Confirmed:       $TOTAL_CONFIRMED"
log "  False positives:  $TOTAL_FALSE_POS"
log "  Duplicates:       $TOTAL_DUPES"
log "  By design:        $TOTAL_BY_DESIGN"
log "  Report: $VERIFIED_FILE"
log "================================================"
